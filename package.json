{
  "name": "dp-table-builder-ui",
  "version": "1.3.1",
  "homepage": "https://www.npmjs.com/package/dp-table-builder-ui",
  "description": "Handsontable grid implementation",
  "main": "dist/index.js",
  "scripts": {
    "audit": "npx auditjs ossi --whitelist ./audit-allowlist.json --quiet -u $OSSINDEX_USERNAME -p $OSSINDEX_TOKEN",
    "start": "webpack-dev-server",
    "clean": "rimraf dist",
    "build": "babel src -d dist && npm run csscopy",
    "csscopy": "copyfiles -u 1 src/**/*.scss dist",
    "production": "cross-env npm run clean && webpack --config webpack.production.config.js --progress --profile --colors",
    "lint": "eslint ./src/**/**.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "coverage": "jest --coverage",
    "precommit": "cross-env npm run lint && npm test",
    "prepush": "cross-env npm run lint && npm test"
  },
  "author": "ons-digital-publishing",
  "contributors": [
    "Mas Ahmad <masahmad7@gmail.com>"
  ],
  "repository": "github:ONSdigital/dp-table-builder-ui",
  "license": "MIT",
  "jest": {
    "testEnvironment": "jsdom",
    "setupFiles": [
      "<rootDir>/config/jest/shim.js"
    ],
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "collectCoverageFrom": [
      "app/**/*.{js,jsx,ts,tsx}"
    ],
    "modulePathIgnorePatterns": [
      "test-app"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/config/jest/assetsTransformer.js",
      "\\.(css|less)$": "<rootDir>/config/jest/assetsTransformer.js"
    },
    "testMatch": [
      "**/?(*.)(spec|test).js?(x)"
    ],
    "transform": {
      "\\.js$": "babel-jest"
    },
    "globals": {
      "__HOT_BUILD_DATE__": "",
      "__HOT_PACKAGE_NAME__": "",
      "__HOT_VERSION__": "",
      "__HOT_BASE_VERSION__": ""
    }
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "moment": "^2.29.4"
  },
  "dependencies": {
    "babel-polyfill": "^6.26.0",
    "cross-env": "^7.0.3",
    "file-saver": "^1.3.3",
    "react": "16.13.1",
    "react-dom": "16.13.1",
    "react-handsontable": "^0.3.1",
    "react-hot-loader": "4.0.0-beta.1",
    "react-router-dom": "4.2.2"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-async-to-generator": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "babel-core": "7.0.0-bridge.0",
    "babel-eslint": "^10.0.0",
    "babel-jest": "^30.4.1",
    "babel-loader": "^8.0.0",
    "copy-webpack-plugin": "^6.4.1",
    "copyfiles": "^1.0.0",
    "core-js": "^2.5.3",
    "css-loader": "^5.2.7",
    "enzyme": "3.3.0",
    "enzyme-adapter-react-16": "^1.15.4",
    "eslint": "^7.32.0",
    "eslint-config-airbnb": "^18.2.1",
    "eslint-loader": "^4.0.2",
    "eslint-plugin-import": "^2.25.4",
    "eslint-plugin-jsx-a11y": "^6.5.1",
    "eslint-plugin-react": "^7.28.0",
    "eslint-plugin-react-hooks": "^4.3.0",
    "mini-css-extract-plugin": "^1.6.2",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^4.5.2",
    "husky": "0.15.0-beta.2",
    "jest": "^30.4.1",
    "jest-environment-jsdom": "^30.4.1",
    "sass": "^1.101.0",
    "auditjs": "^5.0.2",
    "webpack-cli": "^3.3.12",
    "react-test-renderer": "16.13.1",
    "rimraf": "2.6.2",
    "sass-loader": "^10.4.1",
    "style-loader": "^2.0.0",
    "url-loader": "^4.1.1",
    "webpack": "^4.46.0",
    "webpack-dev-server": "^3.11.3"
  }
}
